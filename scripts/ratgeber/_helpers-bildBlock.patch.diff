 export function tabelleBlock(titel, zeilen) {
   return {
     id: uid(),
     blockType: 'tabelle',
     titel,
     zeilen: zeilen.map((zeile) => ({
       id: zeile.id ?? uid(),
       ...zeile,
     })),
   }
 }
